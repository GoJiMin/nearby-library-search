{
  "name": "@nearby-library-search/workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:root",
    "dev:root": "vite",
    "dev:web": "pnpm --filter @nearby-library-search/web dev",
    "dev:bff": "pnpm --filter @nearby-library-search/bff dev",
    "dev:all": "pnpm --parallel --filter @nearby-library-search/web --filter @nearby-library-search/bff dev",
    "build": "pnpm run build:root",
    "build:root": "vite build",
    "build:web": "pnpm --filter @nearby-library-search/web build",
    "build:bff": "pnpm --filter @nearby-library-search/bff build",
    "build:all": "pnpm -r --if-present build",
    "format": "prettier . --write",
    "lint": "pnpm run lint:root",
    "lint:root": "eslint .",
    "preview": "pnpm run preview:root",
    "preview:root": "vite preview",
    "test": "pnpm run test:root",
    "test:root": "vitest",
    "test:run": "pnpm run test:run:root",
    "test:run:root": "vitest run",
    "typecheck:web": "pnpm --filter @nearby-library-search/web exec tsc -p tsconfig.json",
    "typecheck:bff": "pnpm --filter @nearby-library-search/bff exec tsc -p tsconfig.json",
    "typecheck:all": "pnpm -r --if-present exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
