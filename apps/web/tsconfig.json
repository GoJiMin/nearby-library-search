{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "composite": true,
    "paths": {
      "@nearby-library-search/contracts": ["../../packages/contracts/src/index.ts"],
      "@/*": ["./src/*"]
    }
  },
  "references": [{ "path": "../../packages/contracts" }],
  "include": ["src"]
}
